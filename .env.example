# ============================================================
# Kanban Board — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# .env is gitignored — NEVER commit it.
# All variables marked "REQUIRED IN PROD" must be set in your
# hosting dashboard (Railway, Fly.io, etc.) before deploying.
# ============================================================


# ------------------------------------------------------------
# GENERAL
# ------------------------------------------------------------

# Node environment: development | test | production
NODE_ENV=development


# ------------------------------------------------------------
# API (NestJS) — apps/api
# ------------------------------------------------------------

# Port the NestJS server listens on
API_PORT=3000

# Full public URL of the API (used by frontend to connect)
# Local:  http://localhost:3000
# Prod:   https://your-api.up.railway.app   # REQUIRED IN PROD
API_URL=http://localhost:3000


# ------------------------------------------------------------
# JWT AUTH
# ------------------------------------------------------------

# Long random string used to sign JWT tokens.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUIRED IN PROD
JWT_SECRET=replace_me_with_a_long_random_secret_at_least_64_chars

# Token expiry duration (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN=7d


# ------------------------------------------------------------
# MONGODB
# ------------------------------------------------------------

# Root credentials for the MongoDB Docker container (local dev only)
MONGO_USER=admin
MONGO_PASS=changeme
MONGO_DB=kanban

# Full Mongoose connection URI.
# Local (matches docker-compose):  mongodb://admin:changeme@mongo:27017/kanban?authSource=admin
# Railway plugin auto-injects:     mongodb+srv://...    # REQUIRED IN PROD
MONGO_URI=mongodb://admin:changeme@localhost:27017/kanban?authSource=admin


# ------------------------------------------------------------
# WEB (React/Vite) — apps/web
# ------------------------------------------------------------
# Vite requires public env vars to be prefixed with VITE_

# Full public URL of the API consumed by the browser
VITE_API_URL=http://localhost:3000

# Socket.IO namespace (must match SOCKET_NAMESPACE in shared-constants)
VITE_SOCKET_NAMESPACE=/board


# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------

# Comma-separated list of allowed origins for the NestJS CORS config
# Local:  http://localhost:4200
# Prod:   https://your-frontend.up.railway.app   # REQUIRED IN PROD
WEB_URL=http://localhost:4200


# ------------------------------------------------------------
# BCRYPT
# ------------------------------------------------------------

# Cost factor for password hashing (10–12 recommended; higher = slower)
BCRYPT_ROUNDS=12


# ------------------------------------------------------------
# DOCKER (local dev only — used by docker-compose.yml)
# ------------------------------------------------------------

# These mirror MONGO_USER / MONGO_PASS above.
# Docker Compose reads them to initialise the MongoDB container.
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme
MONGO_INITDB_DATABASE=kanban


# ------------------------------------------------------------
# OPTIONAL — Logging
# ------------------------------------------------------------

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Pretty-print logs in development (true | false)
# Set to false in production for JSON structured logs
LOG_PRETTY=true
